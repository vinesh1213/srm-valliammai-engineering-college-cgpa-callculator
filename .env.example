# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to git.

# Backend Configuration
NODE_ENV=production
PORT=3000

# Google Vision API — restrict this key to Cloud Vision API only
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=sk-xxxxxxxxxxxxx

# Frontend Origin (for CORS) — set to your Render app URL in production
FRONTEND_ORIGIN=https://srm-valliammai-engineering-college-cgpa.onrender.com
